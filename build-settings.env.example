# Build Settings
# These settings control how the build process names and packages your custom module

# Required: The name of your custom module/addon
ADDON_NAME=TalisAspireIntegration

# Optional: Institution and View IDs for deployment-specific builds
# When both are set, the dist folder and zip will be named: {INST_ID}-{VIEW_ID}
# When not set, the dist folder and zip will be named: {ADDON_NAME}
# Uncomment and configure these for institution-specific deployments:
# INST_ID=01BC_INST
# VIEW_ID=ndeView

# Optional: Asset base URL for CDN or static hosting
# Leave empty for relative paths
ASSET_BASE_URL=
